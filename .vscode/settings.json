{
  "java.format.settings.url": "/workspaces/common-standards/Common-Standards-Eclipse-Code-Profile.xml",
  "java.completion.importOrder": ["#", "java", "javax", "org", "com", ""],
  "java.format.settings.profile": "Common Standards Eclipse Code Profile for Java",
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.compile.nullAnalysis.mode": "disabled",
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.fixAll.java": "always"
  },
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "[xml]": {
    "editor.tabSize": 4
  }
}
