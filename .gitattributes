# Default: normalize to LF in repo, checkout as LF
* text=auto eol=lf

# Java, XML, YAML — always LF
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts — always LF
*.sh text eol=lf
mvnw text eol=lf

# Windows scripts — always CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binaries — no line ending conversion
*.jar binary
*.png binary
*.jpg binary
*.gif binary
