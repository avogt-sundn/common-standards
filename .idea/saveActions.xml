<?xml version="1.0" encoding="UTF-8"?>
<project version="4">
  <!--
    IntelliJ "Actions on Save" configuration (Settings > Tools > Actions on Save).
    Approximates the Eclipse clean-up profile on-save behavior.

    Covered rules:
      format_source_code / correct_indentation  → reformatCode
      organize_imports / remove_unused_imports  → optimizeImports
      make_variable_declarations_final
      make_local_variable_final
      make_parameters_final                     → addFinalModifier (local vars + params)
      add_missing_override_annotations          → addMissingOverrideAnnotation
  -->
  <component name="SaveActionsSettings">
    <option name="activateOnSave" value="true" />
    <option name="reformatCode" value="true" />
    <option name="optimizeImports" value="true" />
    <option name="addFinalModifier" value="true" />
    <option name="addMissingOverrideAnnotation" value="true" />
  </component>
</project>
