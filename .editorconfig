root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 2
max_line_length = 120
continuation_indent_size = 2

[*.xml]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{ts,js,mjs}]
indent_style = space
indent_size = 2
max_line_length = 140

[*.html]
indent_style = space
indent_size = 2
max_line_length = 140

[*.{css,scss}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[{mvnw,*.sh}]
end_of_line = lf

[*.{cmd,bat}]
end_of_line = crlf
