<?xml version="1.0" encoding="UTF-8"?>
<project version="4">
  <!--
    IntelliJ built-in "Actions on Save" configuration (Settings > Tools > Actions on Save).
    Approximates the Eclipse clean-up profile on-save behavior.

    Covered rules:
      format_source_code / correct_indentation  → FormatOnSaveOptions (reformat code)
      organize_imports / remove_unused_imports  → OptimizeOnSaveOptions (optimize imports)

    Not covered automatically (configure manually via Actions on Save > "Run code cleanup"):
      make_variable_declarations_final
      make_local_variable_final
      make_parameters_final                     → enable "Add final modifier" inspection in cleanup profile
      add_missing_override_annotations          → enable "Missing @Override" inspection in cleanup profile
  -->
  <component name="FormatOnSaveOptions">
    <option name="myRunOnSave" value="true" />
  </component>
  <component name="OptimizeOnSaveOptions">
    <option name="myRunOnSave" value="true" />
  </component>
</project>
